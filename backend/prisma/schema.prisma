generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearchPostgres"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             Int             @id @default(autoincrement())
  username       String          @unique
  name           String?         @db.VarChar(100)
  password       String?         @db.VarChar(255)
  googleId       String?         @unique @db.VarChar(255)
  githubId       String?         @unique @db.VarChar(255)
  isActive       Boolean         @default(true)
  roleId         Int
  updatedAt      DateTime        @updatedAt
  createdAt      DateTime        @default(now())
  avatar         String?         @db.VarChar(255)
  projects       Project[]
  role           Role            @relation("UserRoles", fields: [roleId], references: [id])
  userProfile    UserProfile?
  tradingLogs    TradingLog[]
  strategies     Strategy[]
  tradingAccount TradingAccount?
  wallets        Wallet[]
  assets         Asset[]
  loans          Loan[]
  monthlyBudgets MonthlyBudget[]
  aiSettings     UserAiSettings?
}

model UserProfile {
  id             Int       @id @default(autoincrement())
  userId         Int       @unique
  name           String?   @db.VarChar(100)
  avatar         String?   @db.VarChar(255)
  email          String?   @unique @db.VarChar(100)
  phone          String?   @db.VarChar(20)
  dateOfBirth    DateTime?
  description    String?   @db.VarChar(255)
  address        String?   @db.VarChar(255)
  bio            String?   @db.VarChar(255)
  location       String?   @db.VarChar(100)
  website        String?   @db.VarChar(100)
  socialLinks    String?   @db.VarChar(255)
  interests      String?   @db.VarChar(255)
  theme          String    @default("system")
  language       String    @default("en")
  timezone       String    @default("UTC")
  skills         String?   @db.Text
  education      String?   @db.Text
  experience     String?   @db.Text
  achievements   String?   @db.VarChar(255)
  certifications String?   @db.VarChar(255)
  hobbies        String?   @db.VarChar(255)
  languages      String?   @db.VarChar(255)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  user           User      @relation(fields: [userId], references: [id])
}

model Permission {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String?  @db.VarChar(100)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  roles       Role[]   @relation("RolePermissions")
}

model Role {
  id          Int          @id @default(autoincrement())
  name        String       @unique
  description String?      @db.VarChar(100)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  users       User[]       @relation("UserRoles")
  permissions Permission[] @relation("RolePermissions")
}

model Project {
  id          Int      @id @default(autoincrement())
  title       String   @unique @db.VarChar(100)
  description String?  @db.VarChar(500)
  ownerId     Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  type        String
  status      String   @default("ACTIVE")
  columns     String[]
  tags        String[]
  version     String   @default("1.0")
  phases      Phase[]
  owner       User     @relation(fields: [ownerId], references: [id])
  tickets     Ticket[]
}

model Phase {
  id          Int       @id @default(autoincrement())
  title       String
  description String?   @db.VarChar(100)
  projectId   Int
  startDate   DateTime?
  endDate     DateTime?
  status      String    @default("PLANNED")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  project     Project   @relation(fields: [projectId], references: [id])
  tickets     Ticket[]

  @@unique([projectId, title])
}

model Ticket {
  id          Int      @id @default(autoincrement())
  title       String   @unique
  description String?
  projectId   Int
  phaseId     Int?
  status      String   @default("PENDING")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  priority    String?  @default("medium")
  type        String?  @default("task")
  position    Float    @default(0)
  phase       Phase?   @relation(fields: [phaseId], references: [id])
  project     Project  @relation(fields: [projectId], references: [id])
}

model Article {
  id          Int      @id @default(autoincrement())
  title       String   @unique
  description String?
  body        String
  published   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model TradingLog {
  id        Int      @id @default(autoincrement())
  userId    Int
  content   String   @db.Text
  date      DateTime @unique
  sentiment String   @default("NEUTRAL") // BULLISH | BEARISH | NEUTRAL
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id])

  @@index([userId, date])
}

model Strategy {
  id          Int      @id @default(autoincrement())
  userId      Int
  title       String   @db.VarChar(100)
  description String   @db.Text
  isActive    Boolean  @default(true)
  tags        String[]
  position    Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id])
}

model TradingAccount {
  id        Int      @id @default(autoincrement())
  userId    Int      @unique
  provider  String   @default("Binance")
  apiKey    String?  @db.VarChar(512)
  apiSecret String?  @db.VarChar(512)
  isActive  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id])
}

// Finance Module Enums
enum AssetType {
  PROPERTY
  VEHICLE
  INVESTMENT
  OTHER
}

enum LoanType {
  PAYABLE // Loans you owe to others
  RECEIVABLE // Loans others owe you
}

enum LoanStatus {
  ACTIVE
  PAID_OFF
  DEFAULTED
}

enum TransactionType {
  INCOME
  EXPENSE
  TRANSFER
}

// Finance Module Models
model Wallet {
  id           Int           @id @default(autoincrement())
  userId       Int
  name         String // e.g., "Cash", "Techcombank", "Credit Card"
  balance      Float         @default(0)
  currency     String        @default("VND")
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  user         User          @relation(fields: [userId], references: [id])
  transactions Transaction[] @relation("SourceWallet")
  inTransactions Transaction[] @relation("TargetWallet")
}

model Asset {
  id          Int       @id @default(autoincrement())
  userId      Int
  name        String // e.g., "Apartment", "Motorbike"
  type        AssetType
  value       Float // Current estimated value
  description String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  user        User      @relation(fields: [userId], references: [id])
}

model Loan {
  id           Int        @id @default(autoincrement())
  userId       Int
  type         LoanType
  counterparty String // Bank name or person's name
  principal    Float // Original loan amount
  remaining    Float // Amount left to pay/receive
  interestRate Float? // Annual interest rate (optional)
  dueDate      DateTime? // Expected completion date
  status       LoanStatus @default(ACTIVE)
  note         String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  user         User       @relation(fields: [userId], references: [id])
}

model MonthlyBudget {
  id              Int           @id @default(autoincrement())
  userId          Int
  month           Int // 1-12
  year            Int // 2024, 2025...
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  user            User          @relation(fields: [userId], references: [id])
  categories      BudgetCategory[]

  @@unique([userId, month, year])
}

model BudgetCategory {
  id              Int           @id @default(autoincrement())
  monthlyBudgetId Int
  name            String // "Food & Chill", "Learning", "Investment", "Saving"
  limitAmount     Float // How much you plan to spend
  spentAmount     Float         @default(0) // How much actually spent
  affectsBalance  Boolean       @default(true) // Whether transactions in this category deduct from wallet balance
  
  // Automation settings
  isAutomationEnabled Boolean @default(true)
  type                TransactionType @default(EXPENSE)
  automationDay       Int? // 1-31
  targetWalletId      Int?
  automationProcessed Boolean @default(false)
  lastRunAt           DateTime?

  monthlyBudget   MonthlyBudget @relation(fields: [monthlyBudgetId], references: [id], onDelete: Cascade)
}

model Transaction {
  id         Int             @id @default(autoincrement())
  walletId   Int
  toWalletId Int?
  amount     Float
  type       TransactionType
  category   String?
  date       DateTime        @default(now())
  note       String?
  createdAt  DateTime        @default(now())
  wallet     Wallet          @relation("SourceWallet", fields: [walletId], references: [id])
  toWallet   Wallet?         @relation("TargetWallet", fields: [toWalletId], references: [id])
}

model AiEmbedding {
  id         Int      @id @default(autoincrement())
  userId     Int
  domain     String   // 'finance' | 'trading' | 'projects' | 'profile'
  entityType String   // 'Transaction' | 'TradingLog' | 'Ticket' etc.
  entityId   Int
  content    String   @db.Text
  embedding  Unsupported("vector(3072)")
  isDirty    Boolean  @default(false)
  metadata   Json?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([userId, domain])
  @@index([entityType, entityId])
  @@unique([entityType, entityId])
}



model UserMemory {
  id        Int      @id @default(autoincrement())
  userId    Int
  key       String
  value     String   @db.Text
  source    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, key])
}

model UserAiSettings {
  id        Int      @id @default(autoincrement())
  userId    Int      @unique
  provider  String   @default("google") // "google" | "openai" | "anthropic"
  apiKey    String?  @db.VarChar(512)
  model     String?  @default("gemini-1.5-pro-002")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id])
}

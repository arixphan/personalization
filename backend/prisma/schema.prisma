datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client { 
  provider = "prisma-client-js"
  previewFeatures = ["fullTextSearchPostgres"]
}

model User {
  id        Int       @id @default(autoincrement())
  username  String    @unique
  name      String?   @db.VarChar(100)
  avatar    String?   @db.VarChar(255)
  projects  Project[]
  password  String    @db.VarChar(255)
  isActive  Boolean   @default(true)
  roleId    Int
  role      Role      @relation("UserRoles", fields: [roleId], references: [id])
  userProfile UserProfile?
  updatedAt DateTime  @updatedAt
  createdAt DateTime  @default(now())
} 

model UserProfile {
  id          Int      @id @default(autoincrement())
  userId      Int      @unique
  name        String?  @db.VarChar(100)
  avatar     String?  @db.VarChar(255)
  email       String?  @unique @db.VarChar(100)
  phone       String?  @db.VarChar(20)
  dateOfBirth DateTime? // Optional
  description String?  @db.VarChar(255)
  address     String?  @db.VarChar(255)
  bio         String?  @db.VarChar(255)
  location    String?  @db.VarChar(100)
  website     String?  @db.VarChar(100)
  socialLinks String?  @db.VarChar(255) // JSON or comma-separated links
  interests   String?  @db.VarChar(255) // JSON or comma-separated interests
  skills      String?  @db.VarChar(255) // JSON or comma-separated skills
  education   String?  @db.VarChar(255) // JSON or comma-separated education
  experience  String?  @db.VarChar(255) // JSON or comma-separated work experience
  achievements String? @db.VarChar(255) // JSON or comma-separated achievements
  certifications String? @db.VarChar(255) // JSON or comma-separated certifications
  hobbies     String?  @db.VarChar(255) // JSON or comma-separated hobbies
  languages   String?  @db.VarChar(255) // JSON or comma-separated languages
  user        User     @relation(fields: [userId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Permission {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String?  @db.VarChar(100)
  roles       Role[]   @relation("RolePermissions")
  createdAt   DateTime @default(now()) 
  updatedAt   DateTime @updatedAt
}

model Role {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String?  @db.VarChar(100)
  users       User[]   @relation("UserRoles")
  permissions Permission[] @relation("RolePermissions")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Project {
  id          Int      @id @default(autoincrement())
  title       String   @db.VarChar(100) @unique
  type        String   
  description String?  @db.VarChar(500)
  version     String   @default("1.0")
  status      String   @default("ACTIVE") // ACTIVE, ON-HOLD, COMPLETED, ARCHIVED
  columns     String[] @db.Text
  tags        String[] @db.Text
  ownerId     Int
  owner       User     @relation(fields: [ownerId], references: [id])
  tasks       Task[]
  phases      Phase[] 
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Phase {
  id          Int      @id @default(autoincrement())
  title       String   @unique
  description String?  @db.VarChar(100)
  projectId   Int
  project     Project  @relation(fields: [projectId], references: [id])
  tasks       Task[]   
  startDate   DateTime
  endDate     DateTime
  status      String   @default("PLANNED") // PLANNED, IN_PROGRESS, COMPLETED
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Task {
  id          Int      @id @default(autoincrement())
  title       String   @unique
  description String?  @db.VarChar(100)
  projectId   Int
  project     Project  @relation(fields: [projectId], references: [id])
  phaseId     Int?    
  phase       Phase?   @relation(fields: [phaseId], references: [id])
  status      String   @default("PENDING") // PENDING, IN_PROGRESS, COMPLETED
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Article {
  id          Int      @id @default(autoincrement())
  title       String   @unique
  description String?
  body        String
  published   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearchPostgres"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             Int             @id @default(autoincrement())
  username       String          @unique
  name           String?         @db.VarChar(100)
  password       String?         @db.VarChar(255)
  googleId       String?         @unique @db.VarChar(255)
  githubId       String?         @unique @db.VarChar(255)
  isActive       Boolean         @default(true)
  roleId         Int
  updatedAt      DateTime        @updatedAt
  createdAt      DateTime        @default(now())
  avatar         String?         @db.VarChar(255)
  projects       Project[]
  role           Role            @relation("UserRoles", fields: [roleId], references: [id])
  userProfile    UserProfile?
  tradingLogs    TradingLog[]
  strategies     Strategy[]
  tradingAccount TradingAccount?
}

model UserProfile {
  id             Int       @id @default(autoincrement())
  userId         Int       @unique
  name           String?   @db.VarChar(100)
  avatar         String?   @db.VarChar(255)
  email          String?   @unique @db.VarChar(100)
  phone          String?   @db.VarChar(20)
  dateOfBirth    DateTime?
  description    String?   @db.VarChar(255)
  address        String?   @db.VarChar(255)
  bio            String?   @db.VarChar(255)
  location       String?   @db.VarChar(100)
  website        String?   @db.VarChar(100)
  socialLinks    String?   @db.VarChar(255)
  interests      String?   @db.VarChar(255)
  theme          String    @default("system")
  language       String    @default("en")
  timezone       String    @default("UTC")
  skills         String?   @db.Text
  education      String?   @db.Text
  experience     String?   @db.Text
  achievements   String?   @db.VarChar(255)
  certifications String?   @db.VarChar(255)
  hobbies        String?   @db.VarChar(255)
  languages      String?   @db.VarChar(255)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  user           User      @relation(fields: [userId], references: [id])
}

model Permission {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String?  @db.VarChar(100)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  roles       Role[]   @relation("RolePermissions")
}

model Role {
  id          Int          @id @default(autoincrement())
  name        String       @unique
  description String?      @db.VarChar(100)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  users       User[]       @relation("UserRoles")
  permissions Permission[] @relation("RolePermissions")
}

model Project {
  id          Int      @id @default(autoincrement())
  title       String   @unique @db.VarChar(100)
  description String?  @db.VarChar(500)
  ownerId     Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  type        String
  status      String   @default("ACTIVE")
  columns     String[]
  tags        String[]
  version     String   @default("1.0")
  phases      Phase[]
  owner       User     @relation(fields: [ownerId], references: [id])
  tickets     Ticket[]
}

model Phase {
  id          Int       @id @default(autoincrement())
  title       String
  description String?   @db.VarChar(100)
  projectId   Int
  startDate   DateTime?
  endDate     DateTime?
  status      String    @default("PLANNED")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  project     Project   @relation(fields: [projectId], references: [id])
  tickets     Ticket[]

  @@unique([projectId, title])
}

model Ticket {
  id          Int      @id @default(autoincrement())
  title       String   @unique
  description String?
  projectId   Int
  phaseId     Int?
  status      String   @default("PENDING")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  priority    String?  @default("medium")
  type        String?  @default("task")
  position    Float    @default(0)
  phase       Phase?   @relation(fields: [phaseId], references: [id])
  project     Project  @relation(fields: [projectId], references: [id])
}

model Article {
  id          Int      @id @default(autoincrement())
  title       String   @unique
  description String?
  body        String
  published   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model TradingLog {
  id        Int      @id @default(autoincrement())
  userId    Int
  content   String   @db.Text
  date      DateTime @unique
  sentiment String   @default("NEUTRAL") // BULLISH | BEARISH | NEUTRAL
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id])

  @@index([userId, date])
}

model Strategy {
  id          Int      @id @default(autoincrement())
  userId      Int
  title       String   @db.VarChar(100)
  description String   @db.Text
  isActive    Boolean  @default(true)
  tags        String[]
  position    Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id])
}

model TradingAccount {
  id        Int      @id @default(autoincrement())
  userId    Int      @unique
  provider  String   @default("Binance")
  apiKey    String?  @db.VarChar(512)
  apiSecret String?  @db.VarChar(512)
  isActive  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id])
}

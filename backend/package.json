    "@nestjs/core": "catalog:",
    "@nestjs/event-emitter": "^3.0.1",
    "@nestjs/jwt": "catalog:",
    "@nestjs/mapped-types": "catalog:",
    "@nestjs/passport": "catalog:",
    "@nestjs/platform-express": "catalog:",
    "@nestjs/platform-socket.io": "^11.1.17",
    "@nestjs/schedule": "^6.1.1",
    "@nestjs/swagger": "catalog:",
    "@nestjs/throttler": "catalog:",
    "@nestjs/websockets": "^11.1.17",
    "@personalization/shared": "workspace:*",
    "@prisma/client": "catalog:",
    "@types/passport-google-oauth20": "^2.0.17",
    "ai": "^6.0.134",
    "bcrypt": "catalog:",
    "binance-api-node": "^0.13.8",
    "cache-manager": "catalog:",
    "class-transformer": "catalog:",
    "class-validator": "catalog:",
    "cookie-parser": "catalog:",
    "express": "catalog:",
    "googleapis": "^171.4.0",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "catalog:",
    "nestjs-i18n": "^10.6.0",
    "openai": "^6.32.0",
    "passport": "catalog:",
    "passport-google-oauth20": "^2.0.0",
    "passport-jwt": "catalog:",
    "passport-local": "catalog:",
    "multer": "^1.4.5-lts.1",
    "pgvector": "^0.2.1",
    "reflect-metadata": "catalog:",
    "rss-parser": "^3.13.0",
    "rxjs": "catalog:",
    "socket.io": "^4.8.3",
    "zod": "catalog:",
    "zod-to-json-schema": "^3.25.1"

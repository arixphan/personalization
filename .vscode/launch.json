{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Nest Program",
      "request": "attach",
      "skipFiles": ["<node_internals>/**"],
      "cwd": "${workspaceFolder}/backend",
      "type": "node"
    },
    {
      "type": "node",
      "request": "launch",
      "name": "Launch Program",
      "skipFiles": ["<node_internals>/**"],
      "program": "${file}"
    }
  ]
}
